<?xml version="1.0"?>
<extension key="nl.onvergetelijk.googlesync" type="module">
  <file>googlesync</file>
  <name>Onvergetelijk - Google Sync</name>
  <description>Synchroniseert CiviCRM notificatie-groepen naar Google Workspace groepen</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Richard van Oosterhout</author>
    <email>webteam@onvergetelijk.nl</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://www.onvergetelijk.nl</url>
    <url desc="Documentation">https://www.onvergetelijk.nl</url>
    <url desc="Support">https://www.onvergetelijk.nl</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-06-05</releaseDate>
  <version>1.0.0</version>
  <develStage>alpha</develStage>
  <compatibility>
    <ver>6.14</ver>
  </compatibility>
  <comments>Onderdeel van de Onvergetelijk-extensie-suite voor Stichting Onvergetelijke Zomerkampen. Eigen implementatie van Google Groups-sync (vervangt het vertrouwen op org.civicrm.googlegroups voor de sync-logica). Compatibel met CiviCRM 6.14, PHP 8.4 en Smarty 5.</comments>
  <requires>
    <ext>nl.onvergetelijk.base</ext>
  </requires>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Googlesync</namespace>
    <format>25.01.1</format>
    <angularModule>crmGooglesync</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
</extension>
